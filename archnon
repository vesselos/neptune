restart)
mode=8
if [ $EUID -ne 0 ]; then
    echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}user is not ${ORANGE}root${NC}"
    exit 1
fi

echo -e "\n${ORANGE}[${BLUE}*${ORANGE}]${NC} Restarting ${BLUE}ArchNoN's ${P}Anonymous Session${NC}"

pkill -9 tor >/dev/null 2>&1
pkill -9 NetworkManager >/dev/null 2>&1

config

shift
break
;;

resolv)

mode=9

link=$2

if [ -z "$link" ]; then
  echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}Missing address${NC}"
  exit 1
fi

if pgrep -a tor | grep -IE "tor" >/dev/null 2>&1 || ss -tulpn | grep -iE "6969|9150|9151" >/dev/null 2>&1; then

echo -e "\n${P}[${NC}*${P}]${GREEN} Resolving ${YELLOW}'$link'${GREEN}...${NC}"
curl --socks5-hostname 127.0.0.1:9150 "$link" && echo -e "\n${ORANGE}[${NC}+${ORANGE}]${P} "$link", ${GREEN}resolved${NC}" || echo -e "\n${RED}[${NC}-${RED}]${NC} Could not resolv: ${P}$link${NC}"
exit 0

else
   echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}ArchNoN is not running${NC}"
   exit 1
fi

shift
break
;;

config-show)
mode=10

if [ -f /etc/tor/torrc ] && [ -f /etc/resolv.conf ]; then
  echo -e "\n${BLUE}[${NC}*${BLUE}]${P} Torrc: ${NC}"
    cat /etc/tor/torrc
    echo -e "\n${BLUE}[${NC}*${BLUE}]${NC} DNS ${P}(${BLUE}/etc/resolv.conf${P}): ${NC}"
    cat /etc/resolv.conf
else
  echo -e "\n${RED}[${NC}-${RED}]${NC} Not found: ${RED}(${P}/etc/tor/torrc, ${ORANGE}/etc/resolv.conf${RED})${NC}"
  exit 1
fi

