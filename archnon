config-load)
mode=16

if [ $EUID -ne 0 ]; then
    echo -e "\n${RED}[${GREEN}err${RED}]${GREEN} Bad usage: user is not ${RED}root${NC}"
    exit 1
fi

file=$2

if [ -z $file ]; then
    echo -e "\n${RED}[${GREEN}err${RED}]${GREEN} Bad usage: Missing file${NC}"
    echo -e "\n${BLUE}[${YELLOW}warn${BLUE}]${GREEN} usage: ${BLUE}sudo archnon config-load ${YELLOW}<${NC}file${YELLOW}>${NC}"
    exit 1
fi

if [ ! -f $file ]; then
    echo -e "\n${RED}[${GREEN}err${RED}]${GREEN} Bad usage: ${RED}No such file !!${NC}"
    exit 1
fi


if [ -f /etc/tor/torrc ]; then
    
    chattr -i /etc/tor/torrc >/dev/null 2>&1
    
    rm /etc/tor/torrc >/dev/null 2>&1
    touch /etc/tor/torrc >/dev/null 2>&1
    
    echo -e "\n# NOT TOUCH, THIS FILE IS CUSTOM LOAD #" >> /etc/tor/torrc

    cat "$file" >> /etc/tor/torrc && echo -e "\n${BLUE}[${YELLOW}warn${BLUE}]${GREEN} File touched${BLUE}(${GREEN}done${BLUE})${NC}"
    chattr +i /etc/tor/torrc >/dev/null 2>&1
    
    if id debian-tor >/dev/null 2>&1; then
         export TOR_USER="debian-tor"
    elif id tor >/dev/null 2>&1; then
         export TOR_USER="tor"
    elif id toranon >/dev/null 2>&1; then
         export TOR_USER="toranon"
    else
	export TOR_USER=$(id 0)
    fi

    chwon -R $TOR_USER:$TOR_USER /etc/tor/torrc >/dev/null 2>&1

    if tor --verify-config >/dev/null 2>&1; then
	echo -e "\n${BLUE}[${GREEN}notice${BLUE}]${GREEN} Configuration was valid, you must restart ArchNoN to apply it${NC}"
        exit 0
    else
	echo -e "\n${RED}[${GREEN}err${RED}]${GREEN} Bad usage: Configuration was not valid !!${NC}"
	exit 1
    fi
else
	echo -e "\n${RED}[${GREEN}err${RED}]${GREEN} Bad usage: Requested file: ${P}(${YELLOW}/etc/tor/torrc${P}) ${RED}not found !${NC}"
	exit 1
fi

shift
break
