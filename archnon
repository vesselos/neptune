break
;;

config-load)
mode=11

if [ $EUID -ne 0 ]; then
    echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}user is not root${NC}"
    exit 1
fi

file=$2

if [ -z $file ]; then
    echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}Missing file${NC}"
    echo -e "\n${BLUE}[${NC}*${BLUE}]${ORANGE} usage: ${BLUE}sudo archnon config-load ${YELLOW}<${NC}file${YELLOW}>${NC}"
    exit 1
fi

if [ ! -f $file ]; then
    echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${YELLOW}"$2"${NC}, ${RED}No such file !!${NC}"
    exit 1
fi


if [ -f /etc/tor/torrc ]; then
    
    chattr -i /etc/tor/torrc >/dev/null 2>&1
    
    rm /etc/tor/torrc >/dev/null 2>&1
    touch /etc/tor/torrc >/dev/null 2>&1
    
    echo -e "\n# NOT TOUCH, THIS FILE IS CUSTOM LOAD #" >> /etc/tor/torrc
    
    # Sorry but changing Tor ports may break the script #
    
    echo -e "\n# Do NOT change Tor ports, it may break script's firewall logic !! #\nTransPort 127.0.0.1:6969 IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr\nDNSPort 127.0.0.1:5353 IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr\nSocksPort 127.0.0.1:9150 IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr\nControlPort 127.0.0.1:9151" >> /etc/tor/torrc

    cat "$file" >> /etc/tor/torrc && echo -e "\n${BLUE}[${NC}*${BLUE}]${NC} File touched${BLUE}(${GREEN}done${BLUE})${NC}"
    chattr +i /etc/tor/torrc >/dev/null 2>&1
    
    if id debian-tor >/dev/null 2>&1; then
         export TOR_USER="debian-tor"
    elif id tor >/dev/null 2>&1; then
         export TOR_USER="tor"
    elif id toranon >/dev/null 2>&1; then
         export TOR_USER="toranon"
    else
	export TOR_USER=$(id 0)
    fi

    chwon -R $TOR_USER:$TOR_USER /etc/tor/torrc >/dev/null 2>&1

    if tor --verify-config >/dev/null 2>&1; then
	echo -e "\n${ORANGE}[${NC}*${ORANGE}]${GREEN} Valid${NC}, restart ArchNoN to apply${NC}"
        exit 0
    else
	echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}Invalid Torrc${NC}"
	exit 1
    fi
else
	echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${YELLOW}'/etc/tor/torrc'${NC}: ${RED}No such file${NC}"
	exit 1
fi

shift
break
;;

