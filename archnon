#!/bin/bash

# Colors

RED="\e[1;31m"

GREEN="\e[1;32m"

BLUE="\e[1;34m"

P="\e[1;35m"

YELLOW="\e[1;33m"

NC="\e[0m"

# Dependencies && pkg managers

if ! (command -v nc >/dev/null 2>&1 && command -v curl >/dev/null 2>&1 && command -v tor >/dev/null 2>&1 && command -v NetworkManager >/dev/null 2>&1 && command -v bash >/dev/null 2>&1 && command -v nft >/dev/null 2>&1 && command -v pkill >/dev/null 2>&1 && command -v sudo >/dev/null 2>&1); then

       if [[ $(command -v apt) ]]; then
           
           pkgs=( netcat-openbsd tor curl nftables procps network-manager iproute2 coreutils util-linux bash sudo ) 

           if ! apt install "${pkgs[@]}" -y; then
	          echo -e "${RED}[${GREEN}err${RED}]${BLUE} Missing dependencies: ${YELLOW}(${GREEN}${pkgs[@]}${YELLOW}) !!${NC}"
	          exit 1
	   fi
	       wait

        elif [[ $(command -v pacman) ]]; then
              
              pkgs=( openbsd-netcat curl tor nftables procps-ng networkmanager iproute2 coreutils util-linux bash sudo ) 

              if ! pacman -Syy "${pkgs[@]}" --needed --noconfirm --overwrite "*"; then
  		        echo -e "${RED}[${GREEN}err${RED}]${BLUE} Missing dependencies: ${YELLOW}(${GREEN}${pkgs[@]}${YELLOW}) !!${NC}"
	            exit 1
	      fi
	         wait

        elif [[ $(command -v dnf) ]]; then
              
              pkgs=( epel-release nmap-ncat curl tor nftables procps-ng NetworkManager iproute coreutils util-linux bash sudo ) 

              if ! dnf -y install --allowerasing "${pkgs[@]}"; then
	             echo -e "${RED}[${GREEN}err${RED}]${BLUE} Missing dependencies: ${YELLOW}(${GREEN}${pkgs[@]}${YELLOW}) !!${NC}"
	             exit 1
	      fi
	          wait

        elif [[ $(command -v yum) ]]; then

              pkgs=( nmap-ncat curl tor nftables procps-ng NetworkManager iproute coreutils util-linux bash sudo )
          
              if ! yum -y install "${pkgs[@]}"; then
	             echo -e "${RED}[${GREEN}err${RED}]${BLUE} Missing dependencies: ${YELLOW}(${GREEN}${pkgs[@]}${YELLOW}) !!${NC}"
	             exit 1
	      fi
	          wait

        elif [[ $(command -v zypper) ]]; then

              pkgs=( nmap-ncat curl tor nftables procps-ng NetworkManager iproute coreutils util-linux bash sudo )

              if ! zypper --no-interactive install "${pkgs[@]}"; then
	             echo -e "${RED}[${GREEN}err${RED}]${BLUE} Missing dependencies: ${YELLOW}(${GREEN}${pkgs[@]}${YELLOW}) !!${NC}"
	             exit 1
	      fi
	          wait

        elif [[ $(command -v apk) ]]; then

              pkgs=( netcat-openbsd curl tor nftables procps networkmanager iproute2 coreutils util-linux bash sudo )
               
              if ! apk add --no-cache "${pkgs[@]}"; then
	             echo -e "${RED}[${GREEN}err${RED}]${BLUE} Missing dependencies: ${YELLOW}(${GREEN}${pkgs[@]}${YELLOW}) !!${NC}"
	             exit 1
	      fi
	          wait

        elif [[ $(command -v xbps-install) ]]; then

              pkgs=( openbsd-netcat curl tor iproute2 coreutils util-linux bash nftables sudo procps-ng NetworkManager ) 

              if ! xbps-install -Sy -f -y -o "*" "${pkgs[@]}"; then
	             echo -e "${RED}[${GREEN}err${RED}]${BLUE} Missing dependencies: ${YELLOW}(${GREEN}${pkgs[@]}${YELLOW}) !!${NC}"
	             exit 1
	      fi
	          wait
        else
              echo -e "${RED}[${GREEN}err${RED}]${BLUE} Missing dependencies: ${YELLOW}(${GREEN}${pkgs[@]}${YELLOW}) !!${NC}"
              exit 1
        fi
fi

# Service Managers && Boot Automation

if [ ! -f /etc/systemd/system/archnon.service ] && command -v systemctl >/dev/null 2>&1; then
    touch /etc/systemd/system/archnon.service
    cat << 'EOT' > /etc/systemd/system/archnon.service
[Unit]
Description=ArchNoN Custom Service Here !!
[Service]
Type=forking
ExecStart=/usr/bin/archnon start
RemainAfterExit=yes
User=root
[Install]
WantedBy=multi-user.target
EOT
fi

if [ ! -f /etc/sv/archnon/run ] && command -v runit >/dev/null 2>&1; then
    mkdir -p /etc/sv/archnon/
    touch /etc/sv/archnon/run
    cat << 'EOT' > /etc/sv/archnon/run
#!/bin/sh
exec archnon start
EOT
    chmod +x /etc/sv/archnon/run
fi

if [ ! -f /etc/init.d/archnon ] && command -v rc-service >/dev/null 2>&1; then
    touch /etc/init.d/archnon
    cat << 'EOT' > /etc/init.d/archnon
#!/sbin/openrc-run
name=ArchNoN service
command="archnon"
command_args="start"
command_background=true
pidfile="/run/${RC_SVCNAME}.pid"
depend() {
   need net
}
EOT
   chmod +x /etc/init.d/archnon >/dev/null 2>&1
fi

# Torrc && Script Functions

if ! $(tor --verify-config >/dev/null 2>&1); then

echo -e "\n${RED}[${NC}warn${RED}]${GREEN} Tor's configuration file is not valid, Try ${YELLOW}'sudo archnon config-reset'${NC}"

fi

help(){
   echo -e "\n${BLUE}<--- [${GREEN} ArchNoN Actions ${BLUE}] --->${NC}"
   echo -e "\n${BLUE}[${YELLOW}warn${BLUE}]${GREEN} You are using the ${RED}old iptables version, means slower connections/responses. ${GREEN}To fix it i recommend to switch to the ntf version !!${NC}"
   echo -e "\n${P}[${NC}0${P}]${NC} ${BLUE}start ${BLUE}<-----> ${GREEN}Start ArchNoN and ${YELLOW}Applies Firewall rules${NC}"
   echo -e "\n${P}[${NC}1${P}]${NC} ${BLUE}stop: ${BLUE}<-----> ${GREEN}Stop ArchNoN and ${RED}Flushes Firewall rules${NC}"
   echo -e "\n${P}[${NC}2${P}]${NC} ${BLUE}restart: ${BLUE}<-----> ${GREEN}Restart ArchNoN and Firewall rules${NC}"
   echo -e "\n${P}[${NC}4${P}]${NC} ${BLUE}boot-enable: ${BLUE}<-----> ${GREEN}Enables ArchNoN to ${YELLOW}start on boot ${NC}"
   echo -e "\n${P}[${NC}5${P}]${NC} ${BLUE}boot-disable: ${BLUE}<-----> ${RED}Disables ${GREEN}ArchNoN to ${YELLOW}start on boot ${NC}"
   echo -e "\n${P}[${NC}6${P}]${NC} ${BLUE}myip: ${BLUE}<-----> ${GREEN}Show Your ${YELLOW}Public IP Address${NC}"
   echo -e "\n${P}[${NC}7${P}]${NC} ${BLUE}changeid: ${BLUE}<-----> ${GREEN}Change Your ${YELLOW}Public IP Address${NC}"
   echo -e "\n${P}[${NC}9${P}]${NC} ${BLUE}bridges: ${BLUE}<-----> ${GREEN}Load a custom ${YELLOW}Tor bridges configuration${GREEN} for ArchNoN, ${YELLOW}usage: ${GREEN}archnon bridges ${YELLOW}<${NC}file${YELLOW}> <${NC}kind${YELLOW}> <${NC}bridges_binary${YELLOW}>${NC}"
   echo -e "\n${P}[${NC}10${P}]${NC} ${BLUE}config-reset: ${BLUE}<-----> ${GREEN}Reset ${YELLOW}Tor's configuration file (/etc/tor/torrc) ${GREEN}to ArchNoN's default ${NC}"
   echo -e "\n${P}[${NC}11${P}]${NC} ${BLUE}config-show: ${BLUE}<-----> ${GREEN}Shows configuration ${YELLOW}files touched by ArchNoN !! (/etc/tor/torrc, /etc/resolv.conf)${NC}"
   echo -e "\n${P}[${NC}12${P}]${NC} ${BLUE}link: ${BLUE}<-----> ${GREEN}Resolves ${P}.onion ${YELLOW}addresses${NC}"
   echo -e "\n${P}[${NC}13${P}]${NC} ${BLUE}--help|-help|help|-h: ${BLUE}<-----> ${GREEN}Prints this help page${NC}"
}

myip(){

export agent=( 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/148.0.0.0 Safari/537.36' 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/148.0.0.0 Edg/148.0.3967.83' )

if ss -tulpn | grep -iE "6969|9150|9151" >/dev/null 2>&1 || pgrep -a tor | grep -IE "tor" >/dev/null 2>&1; then

   echo -e "\n${BLUE}[${GREEN}notice${BLUE}]${P} Your Tor Public IP${NC}:" && curl --socks5-hostname 127.0.0.1:9150 --user-agent "${agent[$RANDOM % ${#agent[@]}]}" https://check.torproject.org/api/ip

   echo -e "\n${BLUE}[${GREEN}notice${BLUE}]${P} Your Tor ISP${NC}:" && curl --socks5-hostname 127.0.0.1:9150 'ip-api.com?fields=country,countryCode,as,org,asname,proxy,city,region,regionName,isp,currency'
else
   
   echo -e "\n${RED}[${GREEN}notice${RED}]${GREEN} Your Public IP:${NC}" && curl --user-agent "${agent[$RANDOM % ${#agent[@]}]}" https://check.torproject.org/api/ip

   echo -e "\n${RED}[${GREEN}notice${RED}]${GREEN} Your ISP:${NC}" && curl 'ip-api.com?fields=country,countryCode,as,org,asname,proxy,city,region,regionName,isp,currency'
fi

}

start(){

if [ "$EUID" -ne 0 ]; then
    echo -e "\n${RED}[${GREEN}err${RED}]${GREEN} Bad usage: user is not ${RED}root${NC}"
    exit 1
fi

   sudo setenforce 0 >/dev/null 2>&1
   sudo semanage permissive -a unconfined_t >/dev/null 2>&1
   
   # If any nft rule was applied before

   sudo nft flsuh ruleset >/dev/null 2>&1

   mods=( ip_tables iptable_filter x_tables xt_conntrack ipt_REJECT iptable_mangle iptable_nat ipt_MASQUERADE nft_tables )

   for i in "${mods[@]}"; do
         lsmod | grep "$i" >/dev/null 2>&1 || modprobe $i >/dev/null 2>&1
   done

   sysctl -w net.ipv6.conf.all.disable_ipv6=1 >/dev/null 2>&1

   sysctl -w net.ipv4.icmp_echo_ignore_all=1 >/dev/null 2>&1

   sysctl -w net.ipv6.icmp.echo_ignore_all=1 >/dev/null 2>&1

   sysctl -w net.ipv6.conf.lo.disable_ipv6=1 >/dev/null 2>&1

   sysctl --system >/dev/null 2>&1

   pkill -9 tor >/dev/null 2>&1

   pkill -9 NetworkManager >/dev/null 2>&1

   chattr -i /etc/resolv.conf >/dev/null 2>&1

   rm /etc/resolv.conf >/dev/null 2>&1
   touch /etc/resolv.conf >/dev/null 2>&1

   echo -e "\n# <--- Generated by ArchNoN ---> #\n# [ warn ] If you ran start|restart, this file will likely act as a read-only(chmod 600), this is because sometimes NetworkManager likes to overwrite it, which is bad if you are using this script !!. Anyways, if you want to unlock it, simply run 'chattr -i /etc/resolv.conf' as root\nnameserver 127.0.0.1" | tee /etc/resolv.conf >/dev/null 2>&1

   chmod 644 /etc/resolv.conf >/dev/null 2>&1

   chattr +i /etc/resolv.conf >/dev/null 2>&1

   NetworkManager >/dev/null 2>&1
   NetworkManager >/dev/null 2>&1
   NetworkManager >/dev/null 2>&1

   sleep 8

   sudo -u $TOR_USER tor --RunAsDaemon 1 >/dev/null 2>&1

   sudo ip6tables -F >/dev/null 2>&1

   sudo ip6tables -t nat -F >/dev/null 2>&1

   sudo ip6tables -t mangle -F >/dev/null 2>&1

   sudo ip6tables -A INPUT -p icmpv6 --icmpv6-type echo-request -j DROP >/dev/null 2>&1

   sudo ip6tables -P INPUT DROP >/dev/null 2>&1

   sudo ip6tables -P FORWARD DROP >/dev/null 2>&1

   sudo ip6tables -P OUTPUT DROP >/dev/null 2>&1

   sudo iptables -F >/dev/null 2>&1

   sudo iptables -X >/dev/null 2>&1

   sudo iptables -A INPUT -i lo -j ACCEPT >/dev/null 2>&1

   sudo iptables -A OUTPUT -o lo -j ACCEPT >/dev/null 2>&1

   sudo iptables -A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT >/dev/null 2>&1

   sudo iptables -A OUTPUT -m conntrack --ctstate NEW,ESTABLISHED,RELATED -j ACCEPT >/dev/null 2>&1

   sudo iptables -A INPUT -i lo -p icmp --icmp-type echo-request -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT >/dev/null 2>&1

   sudo iptables -A OUTPUT -o lo -p icmp --icmp-type echo-request -m conntrack --ctstate NEW,ESTABLISHED,RELATED -j ACCEPT >/dev/null 2>&1

   sudo iptables -A INPUT -p icmp --icmp-type echo-request -j DROP >/dev/null 2>&1

   sudo iptables -A OUTPUT -p icmp --icmp-type echo-request -j DROP >/dev/null 2>&1

   sudo iptables -A OUTPUT -m owner --uid-owner $TOR_USER -j ACCEPT >/dev/null 2>&1

   sudo iptables -A OUTPUT -p udp -d 127.0.0.1 --dport 5353 -j ACCEPT >/dev/null 2>&1

   sudo iptables -A OUTPUT -p tcp -d 127.0.0.1 --dport 6969 -j ACCEPT >/dev/null 2>&1

   sudo iptables -A OUTPUT -j REJECT >/dev/null 2>&1

   sudo iptables -t nat -F >/dev/null 2>&1

   sudo iptables -t nat -A OUTPUT -m owner --uid-owner $TOR_USER -j RETURN >/dev/null 2>&1

   sudo iptables -t nat -A OUTPUT -d 127.0.0.0/8 -j RETURN >/dev/null 2>&1

   sudo iptables -t nat -A OUTPUT -d 192.168.0.0/16 -j RETURN >/dev/null 2>&1

   sudo iptables -t nat -A OUTPUT -d 10.0.0.0/8 -j RETURN >/dev/null 2>&1

   sudo iptables -t nat -A OUTPUT -d 172.16.0.0/12 -j RETURN >/dev/null 2>&1

   sudo iptables -t nat -A OUTPUT -d 169.254.0.0/16 -j RETURN >/dev/null 2>&1

   sudo iptables -t nat -A OUTPUT -d 255.255.255.255/32 -j RETURN >/dev/null 2>&1

   sudo iptables -t nat -A OUTPUT -d 224.0.0.0/4 -j RETURN >/dev/null 2>&1

   sudo iptables -t nat -A OUTPUT -p udp --dport 53 -j REDIRECT --to-ports 5353 >/dev/null 2>&1

   sudo iptables -t nat -A OUTPUT -p tcp --syn -j REDIRECT --to-ports 6969 >/dev/null 2>&1

   sudo iptables -t nat -I OUTPUT -d 127.0.0.1 -p udp --dport 53 -j REDIRECT --to-ports 5353 >/dev/null 2>&1

   sudo iptables -t nat -I OUTPUT -d 127.0.0.1 -p tcp --dport 53 -j REDIRECT --to-ports 5353 >/dev/null 2>&1

   # if you use ssh

   #sudo iptables -I INPUT -p tcp --dport 22 -j ACCEPT >/dev/null 2>&1

   #sudo iptables -I INPUT -p tcp --dport 22 -j ACCEPT >/dev/null 2>&1

   sudo iptables -P OUTPUT DROP >/dev/null 2>&1

   sudo iptables -P INPUT DROP >/dev/null 2>&1

   sudo iptables -P FORWARD DROP >/dev/null 2>&1

   sleep 8

   sudo -u $TOR_USER tor --RunAsDaemon 1 >/dev/null 2>&1
   echo -e "\n${BLUE}[${GREEN}notice${BLUE}]${GREEN} ArchNoN is running ${BLUE}(${GREEN}done${BLUE})${NC}"
   echo -e "\n${BLUE}[${GREEN}notice${BLUE}]${GREEN} Note: To resolv ${P}.onion ${GREEN}addresses you just have to type '${YELLOW}archnon link <link>'${NC}"
}


config(){

if ! cat /etc/tor/torrc | grep -iE "UseBridges 1" >/dev/null 2>&1; then
   
   chattr -i /etc/tor/torrc >/dev/null 2>&1
   rm /etc/tor/torrc >/dev/null 2>&1
   touch /etc/tor/torrc >/dev/null 2>&1
   cat << 'EOT' > /etc/tor/torrc
# <--- Generated by ArchNoN ---> #
# This Configuration File uses default's template(Provided by tool) #
# Note: if you reading this and want to use with a browser, you would likely have to manually configure a proxy and disable some features that are capable to break your anonimity !!
# This file cant be overwrited (has chattr +i), to unlock it run 'chattr -i /etc/tor/torrc'

CookieAuthentication 0
VirtualAddrNetworkIPv4 10.192.0.0/10
AutomapHostsOnResolve 1
AutomapHostsSuffixes .exit,.onion
TransPort 127.0.0.1:6969 IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr
DNSPort 127.0.0.1:5353 IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr
SocksPort 127.0.0.1:9150 IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr
ControlPort 127.0.0.1:9151
EntryNodes {is},{ch},{fi},{ro}
ExitNodes {is},{ch},{fi},{ro}
StrictNodes 1
MaxCircuitDirtiness 20
ClientUseIPv6 0
ClientPreferIPv6ORPORT 0
ClientRejectInternalAddresses 1

EOT

chattr +i /etc/tor/torrc >/dev/null 2>&1

fi
   if id debian-tor >/dev/null 2>&1; then
       export TOR_USER="debian-tor"
       echo -e "\n${BLUE}[${YELLOW}warn${BLUE}]${GREEN} The Tor user has been detected as: ${P}$TOR_USER${NC}"
   elif id tor >/dev/null 2>&1; then
       export TOR_USER="tor"
       echo -e "\n${BLUE}[${YELLOW}warn${BLUE}]${GREEN} The Tor user has been detected as: ${P}$TOR_USER${NC}"
   elif id toranon >/dev/null 2>&1; then
       export TOR_USER="toranon"
       echo -e "\n${BLUE}[${YELLOW}warn${BLUE}]${GREEN} The Tor user has been detected as: ${P}$TOR_USER${NC}"
   elif echo $TOR_USER >/dev/null 2>&1; then
       echo -e "\n${BLUE}[${YELLOW}warn${BLUE}]${GREEN} The Tor user has been detected as: ${P}$TOR_USER${NC}"
   else
        echo -e "\n${RED}[${GREEN}err${RED}]${GREEN} ArchNoN needs a tor user to apply firewall rules and it could not be found, thats weird !!!${NC}, you must create an user 'tor' manually${NC}"
        exit 1
   fi
	
   chown -R $TOR_USER:$TOR_USER /etc/tor/torrc >/dev/null 2>&1
   chown -R $TOR_USER:$TOR_USER /var/lib/tor >/dev/null 2>&1
   chattr +i /etc/tor/torrc >/dev/null 2>&1
   start
}

function stop(){

if [ "$EUID" -ne 0 ]; then
    echo -e "\n${RED}[${GREEN}err${RED}]${GREEN} Bad usage: user is not ${RED}root${NC}"
    exit 1
fi

if ss -tulpn | grep -iE "6969|9150|9151" >/dev/null 2>&1 || pgrep -a tor | grep -IE "tor" >/dev/null 2>&1; then

   echo -e "\n${RED}[${YELLOW}warn${RED}]${GREEN} Requested action: ${YELLOW}'stop' ${GREEN}ArchNoN${NC}"
  
   pkill -9 tor >/dev/null 2>&1
   pkill -9 NetworkManager >/dev/null 2>&1

   chattr -i /etc/resolv.conf >/dev/null 2>&1

   rm /etc/resolv.conf >/dev/null 2>&1
   touch /etc/resolv.conf >/dev/null 2>&1

   echo -e "\n# <--- Generated by ArchNoN ---> #\n# warn: This file is blocked and works as read-only file (chmod 600), run 'chattr -i /etc/resolv.conf' to unlock it, this is to o protect you from someone/something that wants to overwrite it, also, the selected address is part of "0 Eyes" privacy's policy(no is saving any kind of information about you, cuz no one is seeing you)\nnameserver 9.9.9.9" | tee /etc/resolv.conf >/dev/null 2>&1

   chattr +i /etc/resolv.conf >/dev/null 2>&1

   NetworkManager >/dev/null 2>&1
   NetworkManager >/dev/null 2>&1
   NetworkManager >/dev/null 2>&1

   sleep 8

   sysctl -w net.ipv6.conf.all.disable_ipv6=0 >/dev/null 2>&1

   sysctl -w net.ipv4.icmp_echo_ignore_all=0 >/dev/null 2>&1

   sysctl -w net.ipv6.icmp.echo_ignore_all=0 >/dev/null 2>&1

   sysctl -w net.ipv6.conf.lo.disable_ipv6=0 >/dev/null 2>&1

   sysctl --system >/dev/null 2>&1

   sudo nft flsuh ruleset >/dev/null 2>&1

   mods=( ip_tables iptable_filterx_tables nf_conntrack xt_conntrack ipt_REJECT iptable_mangle nf_nat iptable_nat ipt_MASQUERADE )
   for i in "${mods[@]}"; do
       lsmod | grep $i >/dev/null 2>&1 || modprobe $i >/dev/null 2>&1
   done

   sudo ip6tables -F >/dev/null 2>&1

   sudo ip6tables -t nat -F >/dev/null 2>&1

   sudo ip6tables -t mangle -F >/dev/null 2>&1

   sudo ip6tables -P INPUT ACCEPT >/dev/null 2>&1

   sudo ip6tables -P FORWARD ACCEPT >/dev/null 2>&1

   sudo ip6tables -P OUTPUT ACCEPT >/dev/null 2>&1

   sudo iptables -F >/dev/null

   sudo iptables -X >/dev/null

   sudo iptables -t nat -X >/dev/null

   sudo iptables -t nat -F >/dev/null

   sudo iptables -P INPUT ACCEPT >/dev/null

   sudo iptables -P FORWARD ACCEPT >/dev/null

   sudo iptables -P OUTPUT ACCEPT >/dev/null

   echo -e "\n${RED}[${GREEN}notice${RED}]${GREEN} ArchNoN has been stopped.${NC}"
   echo -e "\n${BLUE}[${YELLOW}warn${BLUE}]${GREEN} You wont be able to resolv ${P}.onion ${GREEN}addresses now !!${NC}"

else
   echo -e "\n${RED}[${GREEN}err${RED}]${GREEN} ArchNoN is not running${NC}"
   exit 1
fi

}


# Function Calls (parameters)

while [ $# -gt 0 ]; do

case $1 in

start)

mode=1

echo -e "\n${BLUE}[${YELLOW}warn${BLUE}]${P} Requested action: ${YELLOW}'Start'${NC}"

if ! ss -tulpn | grep -iE "6969|9150|9151" >/dev/null 2>&1 || ! pgrep -a tor | grep -IE "tor" >/dev/null 2>&1; then
    echo -e "\n${BLUE}[${GREEN}notice${BLUE}]${GREEN} ArchNoN is starting${NC}"
    config
    exit 0
    shift
    break
else
    echo -e "\n${P}[${YELLOW}warn${P}]${GREEN} ArchNoN is already running${NC}"
    echo -e "\n${BLUE}[${YELLOW}warn${BLUE}]${GREEN} Note: To resolv ${P}.onion ${GREEN}addresses you must use: '${YELLOW}archnon link <link>'${NC}"
    exit 0
    shift 
    break
fi

shift

break

;;

stop)

mode=2

echo -e "\n${BLUE}[${YELLOW}warn${BLUE}]${P} Requested action: ${YELLOW}'Stop'${NC}"

stop

shift

break

;;

myip)

mode=4

echo -e "\n${BLUE}[${YELLOW}warn${BLUE}]${P} Requested action: ${YELLOW}'get_id'${NC}"

myip

shift

break

;;

changeid)

mode=5

echo -e "\n${BLUE}[${YELLOW}warn${BLUE}]${P} Requested action: ${YELLOW}'newnym'${NC}"

if ss -tulpn | grep -iE "6969|9150|9151" >/dev/null 2>&1 || pgrep -a tor | grep -IE "tor" >/dev/null 2>&1; then

   echo -e "AUTHENTICATE \"\"\nSIGNAL NEWNYM\nQUIT" | nc 127.0.0.1 9151 >/dev/null 2>&1

   myip

else
   echo -e "\n${RED}[${GREEN}err${RED}]${GREEN} ArchNoN is not running${NC}"
   exit 1
fi

shift

break

;;

boot-enable)

mode=6

if [ "$EUID" -ne 0 ]; then
    echo -e "\n${RED}[${GREEN}err${RED}]${GREEN} Bad usage: user is not ${RED}root${NC}"
    exit 1
fi

echo -e "\n${BLUE}[${YELLOW}warn${BLUE}]${P} Requested action: ${YELLOW}'boot-enable'${NC}"

if [ -f /etc/systemd/system/archnon.service ] && command -v systemctl >/dev/null 2>&1; then

    if systemctl is-enabled archnon >/dev/null 2>&1; then
       echo -e "\n${P}[${YELLOW}warn${P}]${GREEN} ArchNoN is already enable${NC}"
    else 
        systemctl enable archnon >/dev/null 2>&1 && echo -e "\n${BLUE}[${GREEN}notice${BLUE}]${GREEN} ArchNoN has been enabled${NC}" || echo -e "\n${RED}[${GREEN}err${RED}]${GREEN} Could not enable ArchNoN, check your permissions over the system${NC}" 
    fi
fi

if [ -f /etc/sv/archnon/run ] && command -v runit >/dev/null 2>&1; then
      
        if [ -d /run/runit/service ]; then 
            RSDIR=/run/runit/service                              
        elif [ -d /etc/service ]; then
              RSDIR=/etc/service                                          
        elif [ -d /var/run/service ]; then
              RSDIR=/var/run/service
        fi

