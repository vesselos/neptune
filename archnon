echo -e "\n${P}[${NC}+${P}]${NC} File Touched ${BLUE}(${GREEN}done${BLUE})${NC}"
echo -e "\n${BLUE}[${NC}+${BLUE}]${ORANGE} Restart to apply${NC}"

shift
break
