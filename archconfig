#!/bin/bash

# Colors

RED="\e[1;31m"

GREEN="\e[1;32m"

BLUE="\e[1;34m"

P="\e[1;35m"

YELLOW="\e[1;33m"

ORANGE="\e[38;5;214m"

LB="\e[36m"

NC="\e[0m"

# Banner

echo -e "\n${P}<=[${LB} ArchConfig ${YELLOW}v1.0.0 ${P}]=>"
echo -e "${BLUE}${YELLOW}*${BLUE}] ${YELLOW}Developed By: ${ORANGE}newmasterone27@gmail.com${NC}"

# Tor Ports

TRANS=6969 # TCP Syn
DNS=5353 # Sys DNS resolution
SOCKS=9150 # .onion usage
CONTROL=9151 # new nym

# Usage Warn

usage(){
echo -e "\n${ORANGE}[${BLUE}!${ORANGE}]${NC} usage: ${P}archconfig ${NC}<${GREEN}action${NC}>${NC}"
echo -e "\n${BLUE}[${ORANGE}1${BLUE}]${LB} reset: ${ORANGE}Load ArchNoN's default Torrc template${P}(${BLUE}Tor configuration file${P})${NC}"
echo -e "\n${BLUE}[${ORANGE}2${BLUE}]${LB} show: ${ORANGE}Show Current configuration files as: ${RED}(${YELLOW}/etc/resolv.conf, /etc/tor/torrc ${RED})${NC}"
echo -e "\n${BLUE}[${ORANGE}3${BLUE}]${LB} firewall: ${ORANGE}Show ${RED}Firewall rules file: ${GREEN}/etc/archnon_rules.nft ${ORANGE}template and current system applied chains${NC}"
echo -e "\n${BLUE}[${ORANGE}4${BLUE}]${LB} load: ${ORANGE}Load ${P}custom Torrc${NC}"
echo -e "\n${BLUE}[${ORANGE}5${BLUE}]${LB} bridges: ${ORANGE}Load ${P}custom Torrc ${BLUE}that uses Bridges protocol${NC}"
}

# modes "$1"

while [ $# -gt 0 ]; do
       case $1 in

       reset)
       mode=10

       if [ $EUID -ne 0 ]; then
	   echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}user is not root${NC}"
	   exit 1
       fi
        
        chattr -i /etc/tor/torrc >/dev/null 2>&1

        rm /etc/tor/torrc >/dev/null 2>&1
   	touch /etc/tor/torrc >/dev/null 2>&1

      	cat << EOT > /etc/tor/torrc
	# <--- Generated by ArchNoN ---> #
	# File locked by chattr +i, unlock: sudo chattr -i /etc/tor/torrc
	CookieAuthentication 0
	VirtualAddrNetworkIPv4 10.192.0.0/10
	AutomapHostsOnResolve 1
	AutomapHostsSuffixes .exit,.onion
	TransPort 127.0.0.1:$TRANS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr
	DNSPort 127.0.0.1:$DNS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr
	SocksPort 127.0.0.1:$SOCKS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr
	ControlPort 127.0.0.1:$CONTROL
	EntryNodes {is},{ch},{fi},{ro}
	ExitNodes {is},{ch},{fi},{ro}
	StrictNodes 1
	MaxCircuitDirtiness 10
	ClientUseIPv6 0
	ClientPreferIPv6ORPORT 0
	ClientRejectInternalAddresses 1
	AvoidDiskWrites 1
	EnforceDistinctSubnets 1
	HardwareAccel 1
	
EOT
	chattr +i /etc/tor/torrc

	echo -e "\n${P}[${NC}+${P}]${NC} File Touched ${RED}(${ORANGE}/etc/tor/torrc${RED}), ${BLUE}(${GREEN}done${BLUE})${NC}"
	echo -e "\n${BLUE}[${NC}+${BLUE}]${ORANGE} Restart to apply${NC}"

	shift
	break
;;

load)
mode=11

if [ $EUID -ne 0 ]; then
    echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}user is not root${NC}"
    exit 1
fi

file=$2

if [ -z $file ]; then
    echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}Missing file${NC}"
    echo -e "\n${BLUE}[${NC}*${BLUE}]${ORANGE} usage: ${BLUE}sudo archconfig load ${YELLOW}<${NC}file${YELLOW}>${NC}"
    exit 1
fi

if [ ! -f $file ]; then
    echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${YELLOW}"$2"${NC}, ${RED}NO SUCH FILE${NC}"
    exit 1
fi


if [ -f /etc/tor/torrc ]; then

    chattr -i /etc/tor/torrc >/dev/null 2>&1

    rm /etc/tor/torrc >/dev/null 2>&1
    touch /etc/tor/torrc >/dev/null 2>&1

    echo -e "\n# NOT TOUCH, THIS FILE IS CUSTOM LOAD #" >> /etc/tor/torrc

    # Sorry but changing Tor prots without touching script may break its firewall logic #

    echo -e "\n# Do NOT change Tor ports, it may break script's firewall logic !! #\nTransPort 127.0.0.1:$TRANS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr\nDNSPort 127.0.0.1:$DNS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr\nSocksPort 127.0.0.1:$SOCKS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr\nControlPort 127.0.0.1:$CONTROL" >> /etc/tor/torrc

    cat "$file" >> /etc/tor/torrc && echo -e "\n${BLUE}[${NC}*${BLUE}]${NC} File touched ${LB}'/etc/tor/torrc', ${BLUE}(${GREEN}done${BLUE})${NC}" || echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not modify: ${YELLOW}'/etc/tor/torrc'${NC}"
    chattr +i /etc/tor/torrc >/dev/null 2>&1

    if id debian-tor >/dev/null 2>&1; then
         export TOR_USER="debian-tor"
    elif id tor >/dev/null 2>&1; then
         export TOR_USER="tor"
    elif id toranon >/dev/null 2>&1; then
         export TOR_USER="toranon"
    else
	export TOR_USER=$(id 0)
    fi

    chwon -R $TOR_USER:$TOR_USER /etc/tor/torrc >/dev/null 2>&1

    if tor --verify-config >/dev/null 2>&1; then
	echo -e "\n${ORANGE}[${NC}*${ORANGE}]${GREEN} Valid, ${LB}restart ArchNoN to apply${NC}"
        exit 0
    else
	echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}INVALID CONFIG${NC}"
	exit 1
    fi
else
	echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${YELLOW}'/etc/tor/torrc'${NC}, ${RED}NO SUCH FILE${NC}"
	echo -e "\n${ORANGE}[${YELLOW}!${ORANGE}]${RED} Ensure you ran ArchNoN at least one time !${NC}"
	exit 1
fi

shift
break
;;

firewall)

mode=12

if [ $EUID -ne 0 ]; then
    echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}user is not root${NC}"
    exit 1
fi

if ! [ -f /etc/archnon_rules.nft ]; then
	echo -e "\n${ORANGE}[${YELLOW}!${ORANGE}]${RED} Ensure you ran ArchNoN at least one time !${NC}"
	exit 1
fi

if [ -f /etc/archnon_rules.nft ]; then
    echo -e "\n${BLUE}[${NC}*${BLUE}]${LB} Showing ${GREEN}'/etc/archnon_rules.nft'${NC}, ${ORANGE}(${BLUE}skel file${ORANGE})${NC}"
    sleep 4
    cat /etc/archnon_rules.nft
    echo -e "\n${BLUE}[${NC}+${BLUE}]${GREEN} Keep Looking, take your time..${NC}"
    sleep 12
    echo -e "\n${BLUE}[${NC}*${BLUE}]${P} Showing Current firewall Rules${NC}"
    sleep 4
    nft list ruleset && echo -e "\n${ORANGE}[${NC}+${ORANGE}]${GREEN} done${NC}" || echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not show current firewall rules${NC}"
fi

shift
break

;;

show)
mode=7

if [ -f /etc/tor/torrc ] && [ -f /etc/resolv.conf ]; then
	echo -e "\n${ORANGE}[${BLUE}!${ORANGE}]${LB} Showing current ${P}Torrc${BLUE}(${YELLOW}/etc/tor/torrc${BLUE})${NC}:"
        cat /etc/tor/torrc
        echo -e "\n${ORANGE}[${BLUE}*${ORANGE}]${LB} Showing current ${BLUE}DNS${LB} config${RED}(${YELLOW}/etc/resolv.conf${RED})${NC}:"
         cat /etc/resolv.conf
	 exit 0
else
	echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Not found ${ORANGE}(${YELLOW}/etc/resolv.conf, /etc/tor/torrc${ORANGE})${NC}"
	exit 1
fi
shift
break

;;

bridges)

if [ $EUID -ne 0 ]; then
    echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}user is not root${NC}"
    exit 1
fi

mode=7
file=$2
kind=$3
bin=$4

chattr -i /etc/tor/torrc >/dev/null 2>&1
rm /etc/tor/torrc >/dev/null 2>&1
touch /etc/tor/torrc >/dev/null 2>&1

if [[ -z "$file" || ! -f "$file" || -z "$kind" || ! "$bin" || -z "$bin" ]]; then
    echo -e "\n${ORANGE}[${NC}*${ORANGE}]${YELLOW} Usage: ${P}sudo archconfig bridges ${BLUE}<${NC}file${BLUE}> ${BLUE}<${NC}kind${BLUE}> ${BLUE}<${NC}bin${BLUE}>${NC}"
    echo -e "\n${ORANGE}[${NC}*${ORANGE}]${P} EXAMPLE: ${BLUE}sudo archconfig bridges ${P}bridges.txt ${GREEN}obfs4 ${RED}/usr/bin/obfs4proxy${NC}"
    echo -e "\n${BLUE}[${NC}*${BLUE}]${NC} File ${RED}should ONLY contain the bridges in this format: ${NC}<${YELLOW}'bridge'${NC}> ${YELLOW}<${NC}type${YELLOW}> [${NC}IP${YELLOW}]${GREEN}:${YELLOW}[${NC}PORT${YELLOW}] [${NC}fingerprint${YELLOW}] [${NC}Key=value${YELLOW}]${NC}"
    exit 1
fi

bridges=$(cat "$file")

echo -e "\n# <--- Generated by ArchNoN ---> #\n# Bridges Configuration #\n# NOT TOUCH, THIS FILE IS CUSTOM LOAD #\n# File locked by chattr +i, unlock: sudo chattr -i /etc/tor/torrc #\nCookieAuthentication 0\nVirtualAddrNetworkIPv4 10.192.0.0/10\nAutomapHostsOnResolve 1\nMaxCircuitDirtiness 10\nAutomapHostsSuffixes .exit,.onion\nTransPort 127.0.0.1:$TRANS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr\nDNSPort 127.0.0.1:$DNS\nControlPort 127.0.0.1:$CONTROL\nSocksPort 127.0.0.1:$SOCKS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr\nClientTransportPlugin $kind exec $bin\n$bridges\nUseBridges 1\nClientUseIPv6 0\nClientPreferIPv6ORPORT 0\nClientRejectInternalAddresses 1\nHardwareAccel 1\nEnforceDistinctSubnets 1\nAvoidDiskWrites 1\n" | tee /etc/tor/torrc >/dev/null 2>&1

if tor --verify-config >/dev/null 2>&1; then
   echo -e "\n${P}[${NC}*${P}]${NC} File Touched ${BLUE}(${GREEN}done${BLUE})${NC}"
   echo -e "\n${BLUE}[${NC}*${BLUE}]${ORANGE} Restart to apply${NC}"
   chown -R $TOR_USER:$TOR_USER /etc/tor/torrc
   chown -R $TOR_USER:$TOR_USER /var/lib/tor
   chattr +i /etc/tor/torrc >/dev/null 2>&1
   exit 0
else
   echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}Invalid Torrc${NC}, ${ORANGE}The fix${NC}: ${P}'archconfig reset'${NC}"
   exit 1
fi

shift
break

;;

--help|-help|help)
mode=12

usage
exit 1

shift
break

;;

--*|-*|*)
mode=6

usage
echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}unknown action: ${YELLOW}'$1'${NC}"

shift
break
exit 1

esac
done

if [ -z $mode ]; then
    usage
    exit 1
fi
