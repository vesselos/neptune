#!/bin/bash

# Colors

RED="\e[1;31m"

GREEN="\e[1;32m"

BLUE="\e[1;34m"

P="\e[1;35m"

YELLOW="\e[1;33m"

ORANGE="\e[38;5;214m"

LB="\e[36m"

NC="\e[0m"

# Dependencies && pkg managers

pkgs=(e2fsprogs figlet)

if ! (command -v figlet >/dev/null 2>&1 && command -v chattr >/dev/null 2>&1); then
        if [[ $(command -v apt) ]]; then
                if ! apt install -y ${pkgs[@]}; then
                echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not install missing binary: ${ORANGE}${pkgs[@]}${NC}"
                exit 1
                fi
        elif [[ $(command -v pacman) ]]; then
                if ! pacman -Sy --noconfirm --needed --overwrite "*" ${pkgs[@]}; then
                echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not install missing binary: ${ORANGE}${pkgs[@]}${NC}"
                exit 1
                fi
        elif [[ $(command -v dnf) ]]; then
                if ! dnf install -y --allowerasing ${pkgs[@]}; then
                echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not install missing binary: ${ORANGE}${pkgs[@]}${NC}"
                exit 1
                fi
        elif [[ $(command -v yum) ]]; then
                if ! yum install -y figlet; then
                echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not install missing binary: ${ORANGE}figlet${NC}"
                exit 1
                fi
        elif [[ $(command -v xbps-install) ]]; then
                if ! xbps-install -Sy -f -y "*" ${pkgs[@]}; then
                echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not install missing binary: ${ORANGE}figlet${NC}"
                exit 1
                fi
        elif [[ $(command -v zypper) ]]; then
                if ! zypper install ${pkgs[@]}; then
                echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not install missing binary: ${ORANGE}${pkgs[@]}${NC}"
                exit 1
                fi
        elif [[ $(command -v apk) ]]; then
                if ! apk add --no-cache figlet; then
                echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not install missing binary: ${ORANGE}${pkgs[@]}${NC}"
                exit 1
                fi
        elif [[ $(command -v emerge) ]]; then
                if ! emerge -v --oneshot --keep-going ${pkgs[@]}; then
                echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not install missing binary: ${ORANGE}${pkgs[@]}${NC}"
                exit 1
                fi
        else
                echo -e "\n${RED}[${NC}-${RED}]${NC} Not common: ${RED}Unsuported pkg manager, please install: ${ORANGE}'${pkgs[@]}'${NC}"
                exit 1
        fi
fi

# Banner

echo -e "${RED}" && figlet NumbConfig
echo -n -e "${YELLOW}v1.0.0.2 ${LB}--> ${RED}Numb's Config Manager${NC}"
echo -e "\n"
echo -e "\n${BLUE}[${GREEN}*${BLUE}] ${GREEN}Coded By: ${ORANGE}gmasterone@duck.com${NC}"


# Bind Addr
# Default 127.0.0.1(loopback/lo/localhost)

ADDR=127.0.0.1

# Tor Ports
# Default order: 6969, 5353, 9150, 9151, 8181

TRANS=6969
DNS=5353
SOCKS=9150
CONTROL=9151
HTTP=8181

# I2pd Ports
# Default order: 7070, 4444, 4447

I2pd_HTTP=7070
I2pd_HTTP_proxy=4444
I2pd_socks=4447

# Configuration Files
# Default order: /etc/tor/torrc, /etc/i2pd.conf, /etc/numb_rules.nft

TORRC=/etc/tor/torrc
I2PDCONF=/etc/i2pd.conf
FWFILE=/etc/numb_rules.nft

# Usage Warn

usage(){
echo -e "\n${RED}[${YELLOW}*${RED}]${GREEN} usage: ${P}numbc ${NC}<${GREEN}action${NC}>${NC}"
echo -e "\n${BLUE}[${ORANGE}1${BLUE}]${LB} reset: ${ORANGE}Remplace Torrc with numb's default${NC}"
echo -e "\n${BLUE}[${ORANGE}2${BLUE}]${LB} show: ${ORANGE}Show config files${NC}"
echo -e "\n${BLUE}[${ORANGE}3${BLUE}]${LB} firewall: ${ORANGE}Show ${RED}Firewall rules.${NC}"
echo -e "\n${BLUE}[${ORANGE}4${BLUE}]${LB} load-torrc: ${ORANGE}Load ${P}custom Torrc${NC}"
echo -e "\n${BLUE}[${ORANGE}4${BLUE}]${LB} load-i2pd: ${ORANGE}Load ${P}custom i2pd.conf${NC}"
echo -e "\n${BLUE}[${ORANGE}5${BLUE}]${LB} bridges: ${ORANGE}Load ${P}custom Bridges based Torrc${NC}"
}

# modes "$1"

while [ $# -gt 0 ]; do
       case $1 in

       reset)
       mode=10

       if [ $EUID -ne 0 ]; then
           echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}user is not root${NC}"
           exit 1
       fi

        chattr -i $TORRC >/dev/null 2>&1
        chattr -i $I2PDCONF >/dev/null 2>&1
        rm $I2PDCONF >/dev/null 2>&1
        rm $TORRC >/dev/null 2>&1
	touch $I2PDCONF >/dev/null 2>&1
        touch $TORRC >/dev/null 2>&1

cat << EOT > $TORRC
# <--- Generated by NumbConfig ---> #
# File locked by chattr +i, unlock: sudo chattr -i $TORRC
CookieAuthentication 0
VirtualAddrNetworkIPv4 10.192.0.0/10
AutomapHostsOnResolve 1
AutomapHostsSuffixes .exit,.onion
TransPort $ADDR:$TRANS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr
DNSPort $ADDR:$DNS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr
SocksPort $ADDR:$SOCKS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr
ControlPort $ADDR:$CONTROL
HTTPTunnelPort $ADDR:$HTTP
EntryNodes {is},{ch},{fi},{ro}
ExitNodes {is},{ch},{fi},{ro}
StrictNodes 1
MaxCircuitDirtiness 10
ClientUseIPv6 0
ClientPreferIPv6ORPORT 0
ClientRejectInternalAddresses 1
AvoidDiskWrites 1
EnforceDistinctSubnets 1
HardwareAccel 1
EOT

cat << EOT > $I2PDCONF

# <--- Generated By NumbConfig ---> #
# Default template for I2P Traffic route #
# File locked with chattr +i

daemon = true

ifname = $IFNAME

ipv4 = true
ipv6 = false

[ntcp2]
enabled = true
published = false
port = 4567

[http]
enabled = true
address = $ADDR
port = $I2pd_HTTP
webroot = /
lang = english

[httpproxy]
enabled = true
address = $ADDR
port = $I2pd_HTTP_proxy
keys = transient-proxy
addresshelper = true
outproxy = http://false.i2p

[socksproxy]
enabled = true
address = $ADDR
port = $I2pd_socks
keys = transient-proxy

[sam]
enabled = true
address = $ADDR
port = 7656
portudp = 7655

[i2cp]
enabled = true
address = $ADDR
port = 7654

[i2pcontrol]

enabled = true
address = $ADDR
port = 7650

[reseed]
verify = true

[persist]
profiles = false
addressbook = false

EOT
	chattr +i $I2PDCONF
        chattr +i $TORRC

        echo -e "\n${P}[${NC}+${P}]${NC} Files Touched ${RED}(${ORANGE}$TORRC, $I2PDCONF${RED}), ${BLUE}(${GREEN}done${BLUE})${NC}"
        echo -e "\n${BLUE}[${NC}+${BLUE}]${ORANGE} Restart numb to apply${NC}"

        shift
        break
;;

load-i2pd)
mode=11

if [ $EUID -ne 0 ]; then
    echo -e "\n${RED}[${NC}err${RED}]${NC} Bad usage: ${RED}user is not root${NC}"
    exit 1
fi

file=$2

if [ -z $file ]; then
    echo -e "\n${RED}[${ORANGE}warn${RED}]${NC} usage: ${BLUE}sudo numbc load-i2pd ${LB}<${NC}file${LB}>${NC}"
    exit 1
fi

if ! [ -f $file ]; then
    echo -e "\n${RED}[${NC}err${RED}]${NC} Bad usage: ${ORANGE}'$2', ${RED}No such file !${NC}"
    exit 1
fi

if [ -f $I2PDCONF ]; then

    chattr -i $I2PDCONF

    echo "# <--- Generated By numbc ---> #\n# NO TOUCH, CUSTOM CONFIG LOAD #\n" | tee $I2PDCONF >/dev/null 2>&1

    rm $I2PDCONF
    touch $I2PDCONF	

    cat $file >> $I2PDCONF && echo -e "\n${BLUE}[${GREEN}notice${BLUE}] ${ORANGE}File Touched${BLUE}(${GREEN}done${BLUE})${NC}" || echo -e "\n${RED}[${NC}err${RED}] ${NC}unknown: ${RED}Could not remplace file !${NC}"    

    chattr +i $I2PDCONF >/dev/null 2>&1    

    echo -e "\n${RED}[${ORANGE}warn${RED}]${GREEN} Ensure your config file contains the same addr:port as numb sets !!${NC}"
    echo -e "\n${RED}[${ORANGE}warn${RED}]${GREEN} You must check numb/numbc to ensure this is the same${NC}"

    exit 0

else
    echo -e "\n${RED}[${NC}err${RED}]${NC} Bad usage: ${ORANGE}'$I2PDCONF', ${RED}no such file !${NC}"
    exit 1
fi

shift
break    
;;

load-torrc)
mode=11

if [ $EUID -ne 0 ]; then
    echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}user is not root${NC}"
    exit 1
fi

file=$2

if [ -z $file ]; then
    echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}Missing file${NC}"
    echo -e "\n${BLUE}[${NC}*${BLUE}]${ORANGE} usage: ${BLUE}sudo numbc load-torrc ${YELLOW}<${NC}file${YELLOW}>${NC}"
    exit 1
fi

if [ ! -f $file ]; then
    echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${YELLOW}"$2"${NC}, ${RED}NO SUCH FILE${NC}"
    exit 1
fi


if [ -f $TORRC ]; then

    chattr -i $TORRC >/dev/null 2>&1

    rm $TORRC >/dev/null 2>&1
    touch $TORRC >/dev/null 2>&1

    echo -e "\n# NOT TOUCH, THIS FILE IS CUSTOM LOAD #" >> $TORRC

    # Sorry but changing Tor prots without touching script may break its firewall logic #

    echo -e "\n# Do NOT change Tor ports, it may break script's firewall logic !! #\nTransPort $ADDR:$TRANS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr\nDNSPort $ADDR:$DNS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr\nSocksPort $ADDR:$SOCKS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr\nControlPort $ADDR:$CONTROL\nHTTPTunnelPort $ADDR:$HTTP" >> $TORRC

    cat "$file" >> $TORRC && echo -e "\n${BLUE}[${NC}*${BLUE}]${NC} File touched ${LB}'$TORRC', ${BLUE}(${GREEN}done${BLUE})${NC}" || echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not modify: ${YELLOW}'$TORRC'${NC}"
    chattr +i $TORRC >/dev/null 2>&1

    if id debian-tor >/dev/null 2>&1; then
         export TOR_USER="debian-tor"
    elif id tor >/dev/null 2>&1; then
         export TOR_USER="tor"
    elif id toranon >/dev/null 2>&1; then
         export TOR_USER="toranon"
    else
        export TOR_USER=$(id 0)
    fi

    chwon -R $TOR_USER:$TOR_USER $TORRC >/dev/null 2>&1

    if tor --verify-config >/dev/null 2>&1; then
        echo -e "\n${ORANGE}[${NC}*${ORANGE}]${GREEN} Valid, ${LB}restart numb to apply${NC}"
        exit 0
    else
        echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}INVALID CONFIG${NC}"
        exit 1
    fi
else
        echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${YELLOW}'$TORRC'${NC}, ${RED}NO SUCH FILE${NC}"
        echo -e "\n${ORANGE}[${YELLOW}!${ORANGE}]${RED} Ensure you ran numb at least one time !${NC}"
        exit 1
fi

shift
break
;;

firewall)

mode=12

if [ $EUID -ne 0 ]; then
    echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}user is not root${NC}"
    exit 1
fi

if ! [ -f $FWFILE ]; then
        echo -e "\n${RED}[${NC}err${RED}]${NC} Not such file: ${ORANGE}'$FWFILE', ${RED}Ensure you ran numb at least one time !${NC}"
        exit 1
fi

if [ -f $FWFILE ]; then
    echo -e "\n${BLUE}[${NC}*${BLUE}]${LB} Showing ${GREEN}'$FWFILE'${NC}, ${ORANGE}(${BLUE}skel file${ORANGE})${NC}"
    sleep 4
    cat $FWFILE
    echo -e "\n${BLUE}[${NC}+${BLUE}]${GREEN} Keep Looking, take your time..${NC}"
    sleep 12
    echo -e "\n${BLUE}[${NC}*${BLUE}]${P} Showing Current firewall Rules${NC}"
    sleep 4
    nft list ruleset && echo -e "\n${ORANGE}[${NC}+${ORANGE}]${GREEN} done${NC}" || echo -e "\n${RED}[${NC}-${RED}]${NC} unknown: ${RED}Could not show current firewall rules${NC}"
fi

shift
break

;;

show)
mode=7

if [ -f $TORRC ] && [ -f $I2PDCONF ] && [ -f /etc/resolv.conf ]; then
        
	echo -e "\n${BLUE}[${GREEN}notice${BLUE}]${GREEN} Showing current ${P}Torrc${BLUE}(${YELLOW}$TORRC${BLUE})${NC}:"
        cat $TORRC
	
	echo -e "\n${BLUE}[${GREEN}notice${BLUE}]${GREEN} Showing current ${YELLOW}I2pd.conf${BLUE}(${ORANGE}$I2PDCONF${BLUE})${NC}:"
        cat $I2PDCONF
	
	echo -e "\n${BLUE}[${GREEN}notice${BLUE}]${GREEN} Showing current DNS config${RED}(${ORANGE}/etc/resolv.conf${RED})${NC}:"
        cat /etc/resolv.conf
        exit 0
else
        echo -e "\n${RED}[${NC}err${RED}]${NC} unknown: ${RED}Missing Files, Posible: (${ORANGE}$TORRC, $I2PDCONF, /etc/resolv.conf${RED})${NC}"
        exit 1
fi

shift
break

;;

bridges)

if [ $EUID -ne 0 ]; then
    echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}user is not root${NC}"
    exit 1
fi

mode=7
file=$2
kind=$3
bin=$4

chattr -i $TORRC >/dev/null 2>&1
rm $TORRC >/dev/null 2>&1
touch $TORRC >/dev/null 2>&1

if [[ -z "$file" || ! -f "$file" || -z "$kind" || ! "$bin" || -z "$bin" ]]; then
    echo -e "\n${ORANGE}[${NC}*${ORANGE}]${P} usage: ${GREEN}sudo numbc bridges ${BLUE}<${NC}file${BLUE}> ${BLUE}<${NC}kind${BLUE}> ${BLUE}<${NC}bin${BLUE}>${NC}"
    echo -e "\n${ORANGE}[${NC}*${ORANGE}]${P} Ex: ${GREEN}sudo numbc bridges ${LB}bridges.txt ${LB}obfs4 ${LB}/usr/bin/obfs4proxy${NC}"
    echo -e "\n${BLUE}[${GREEN}*${BLUE}]${GREEN} File ${RED}should ONLY contain the bridges in this format: ${NC}<${YELLOW}'bridge'${NC}> ${YELLOW}<${NC}type${YELLOW}> [${NC}IP${YELLOW}]${GREEN}:${YELLOW}[${NC}PORT${YELLOW}] [${NC}fingerprint${YELLOW}] [${NC}Key=value${YELLOW}]${NC}"
    exit 1
fi

bridges=$(cat "$file")

echo -e "\n# <--- Generated by numb ---> #\n# Bridges Configuration #\n# NOT TOUCH, THIS FILE IS CUSTOM LOAD #\n# File locked by chattr +i, unlock: sudo chattr -i $TORRC #\nCookieAuthentication 0\nVirtualAddrNetworkIPv4 10.192.0.0/10\nAutomapHostsOnResolve 1\nMaxCircuitDirtiness 10\nAutomapHostsSuffixes .exit,.onion\nTransPort $ADDR:$TRANS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr\nDNSPort $ADDR:$DNS\nControlPort $ADDR:$CONTROL\nSocksPort $ADDR:$SOCKS IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr\nHTTPTunnelPort $ADDR:$HTTP\nClientTransportPlugin $kind exec $bin\n$bridges\nUseBridges 1\nClientUseIPv6 0\nClientPreferIPv6ORPORT 0\nClientRejectInternalAddresses 1\nHardwareAccel 1\nEnforceDistinctSubnets 1\nAvoidDiskWrites 1\n" | tee $TORRC >/dev/null 2>&1

if tor --verify-config >/dev/null 2>&1; then
   echo -e "\n${P}[${NC}*${P}]${NC} File Touched ${BLUE}(${GREEN}done${BLUE})${NC}"
   echo -e "\n${BLUE}[${NC}*${BLUE}]${ORANGE} Restart to apply${NC}"
   chown -R $TOR_USER:$TOR_USER $TORRC
   chown -R $TOR_USER:$TOR_USER /var/lib/tor
   chattr +i $TORRC >/dev/null 2>&1
   exit 0
else
   echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}Invalid Torrc${NC}, ${ORANGE}The fix${NC}: ${P}'numbc reset'${NC}"
   exit 1
fi

shift
break

;;

--help|-help|help)
mode=12

usage
exit 1

shift
break

;;

--*|-*|*)
mode=6

usage
echo -e "\n${RED}[${NC}-${RED}]${NC} Bad usage: ${RED}unknown action: ${YELLOW}'$1'${NC}"

shift
break
exit 1

esac
done

if [ -z $mode ]; then
    usage
    exit 1
fi
